#!/usr/bin/env bash
# Launches a personal Cursor instance with settings merged from base + overrides.
# Overrides (e.g. theme) live in ~/.dotfiles/cursor-personal-overrides.json.
# Re-merges automatically whenever base settings.json changes while running.

BASE="$HOME/.config/Cursor/User/settings.json"
OVERRIDES="$HOME/.dotfiles/cursor-personal-overrides.json"
PERSONAL="$HOME/.cursor-profile-personal/User/settings.json"

merge() {
  jq -s '.[0] * .[1]' "$BASE" "$OVERRIDES" > "$PERSONAL"
}

# Remove symlink if present, replace with merged file
[ -L "$PERSONAL" ] && rm "$PERSONAL"
merge

# Watch base settings for changes and re-merge in background
if command -v inotifywait &>/dev/null; then
  (
    while inotifywait -e close_write "$BASE" &>/dev/null; do
      merge
    done
  ) &
  WATCHER_PID=$!
fi

cursor --user-data-dir="$HOME/.cursor-profile-personal" \
       --extensions-dir="$HOME/.cursor/extensions" \
       "$@"

# Clean up watcher when cursor exits
[ -n "$WATCHER_PID" ] && kill "$WATCHER_PID" 2>/dev/null
