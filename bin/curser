#!/usr/bin/env bash
# curser — launch a personal Cursor instance alongside the default (work) one.
#
# Problem:  Cursor supports only one logged-in account at a time. This script
#           runs a second instance under a separate --user-data-dir so you can
#           log into a personal account while the default "cursor" stays on the
#           work account.
#
# Strategy:
#   - settings.json  → merged (base + overrides) so themes can differ
#   - keybindings    → symlinked from default profile
#   - snippets       → symlinked from default profile
#   - extensions     → shared via --extensions-dir pointing at ~/.cursor/extensions
#   - extension registry (CachedProfilesData) → symlinked so both instances
#     see the same "installed" list without duplicating storage
#
# Dependencies: jq, inotifywait (optional, from inotify-tools)
#
# Files:
#   ~/.dotfiles/cursor-personal-overrides.json  — JSON overrides (e.g. theme)
#   ~/.cursor-profile-personal/                 — user-data-dir for this instance
#
# See also: curser-oauth, cursor-uri-handler (OAuth callback routing)

BASE="$HOME/.config/Cursor/User/settings.json"
OVERRIDES="$HOME/.dotfiles/cursor-personal-overrides.json"
PERSONAL_DIR="$HOME/.cursor-profile-personal"
PERSONAL="$PERSONAL_DIR/User/settings.json"
DEFAULT_PROFILE="$HOME/.config/Cursor/CachedProfilesData/__default__profile__"
PERSONAL_PROFILE="$PERSONAL_DIR/CachedProfilesData/__default__profile__"

merge() {
  jq -s '.[0] * .[1]' "$BASE" "$OVERRIDES" > "$PERSONAL"
}

# --- settings.json: merged file (not a symlink) ---
mkdir -p "$PERSONAL_DIR/User"
[ -L "$PERSONAL" ] && rm "$PERSONAL"
merge

# --- keybindings + snippets: symlinked ---
ln -sf "$HOME/.config/Cursor/User/keybindings.json" "$PERSONAL_DIR/User/keybindings.json"
ln -sf "$HOME/.config/Cursor/User/snippets"         "$PERSONAL_DIR/User/snippets"

# --- extension registry: symlinked so installs are shared ---
mkdir -p "$PERSONAL_PROFILE"
ln -sf "$DEFAULT_PROFILE/extensions.user.cache"    "$PERSONAL_PROFILE/extensions.user.cache"
ln -sf "$DEFAULT_PROFILE/extensions.builtin.cache" "$PERSONAL_PROFILE/extensions.builtin.cache"

# Watch base settings for changes and re-merge in background
if command -v inotifywait &>/dev/null; then
  (
    while inotifywait -e close_write "$BASE" &>/dev/null; do
      merge
    done
  ) &
  WATCHER_PID=$!
fi

cursor --user-data-dir="$PERSONAL_DIR" \
       --extensions-dir="$HOME/.cursor/extensions" \
       "$@"

# Clean up watcher when cursor exits
[ -n "$WATCHER_PID" ] && kill "$WATCHER_PID" 2>/dev/null
